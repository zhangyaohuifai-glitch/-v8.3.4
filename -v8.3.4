    <button class="btn btn-secondary" id="btn-admin-back">返回大堂</button>
</div>

<div id="toast" class="toast"></div>

<script>
(function() {
    firebase.initializeApp({
        apiKey: "AIzaSyAFcVQgfloxuzYeoHg7wgiKLfen1W3RaEk",
        authDomain: "vanv6-c5bab.firebaseapp.com",
        databaseURL: "https://vanv6-c5bab-default-rtdb.asia-southeast1.firebasedatabase.app",
        projectId: "vanv6-c5bab"
    });
    const db = firebase.database();
    const activeRef = db.ref("van/active_buses");
    const msgRef = db.ref("van/messages");
    const announceRef = db.ref("van/announcements");

    const BUSY = ["大棠黃泥墩","大棠山路","大棠村迴旋處","水蕉新村","曉門","南坑排","南坑村","紅棗田","崇正公立學校","深涌村","禮修村公廁","蝶翠峰","富達廣場","合益路","鳳翔路","元朗站H出口（朗明街）"];
    const NORMAL = ["大棠黃泥墩","大棠山路","大棠村迴旋處","水蕉新村","曉門","南坑排","南坑村","紅棗田","崇正公立學校","深涌村","禮修村公廁","蝶翠峰","富達廣場","教育路麥當勞","鄉議局中學","大球場","元朗廣場","余仁生（大馬路）","家居站","元朗站H出口（朗明街）","鳳翔路","合益路","富達廣場(回程)","蝶翠峰(回程)","禮修村公廁(回程)","深涌村(回程)","崇正公立學校(回程)","紅棗田(回程)","南坑村(回程)","南坑排(回程)","曉門(回程)","水蕉新村(回程)","大棠村迴旋處(回程)","大棠山路(回程)","大棠黃泥墩(終點站)"];
    const COORDS_BUSY = [{lat:22.416277,lng:114.021894},{lat:22.416252,lng:114.024020},{lat:22.418172,lng:114.025328},{lat:22.422033,lng:114.028292},{lat:22.422488,lng:114.029555},{lat:22.422697,lng:114.030932},{lat:22.423627,lng:114.032177},{lat:22.425730,lng:114.031150},{lat:22.429900,lng:114.028588},{lat:22.433535,lng:114.028572},{lat:22.435330,lng:114.028650},{lat:22.437075,lng:114.029522},{lat:22.441063,lng:114.029452},{lat:22.441865,lng:114.030613},{lat:22.441895,lng:114.032175},{lat:22.445882,lng:114.036110}];
    const COORDS_NORMAL = [{lat:22.416277,lng:114.021894},{lat:22.416252,lng:114.024020},{lat:22.418172,lng:114.025328},{lat:22.422033,lng:114.028292},{lat:22.422488,lng:114.029555},{lat:22.422697,lng:114.030932},{lat:22.423627,lng:114.032177},{lat:22.425730,lng:114.031150},{lat:22.429900,lng:114.028588},{lat:22.433535,lng:114.028572},{lat:22.435330,lng:114.028650},{lat:22.437075,lng:114.029522},{lat:22.441063,lng:114.029452},{lat:22.443030,lng:114.027818},{lat:22.443048,lng:114.025135},{lat:22.443182,lng:114.022137},{lat:22.444632,lng:114.023758},{lat:22.444547,lng:114.027602},{lat:22.444520,lng:114.030492},{lat:22.445882,lng:114.036110},{lat:22.441895,lng:114.032175},{lat:22.441865,lng:114.030613},{lat:22.441063,lng:114.029452},{lat:22.437075,lng:114.029522},{lat:22.435330,lng:114.028650},{lat:22.433535,lng:114.028572},{lat:22.429900,lng:114.028588},{lat:22.425730,lng:114.031150},{lat:22.423627,lng:114.032177},{lat:22.422697,lng:114.030932},{lat:22.422488,lng:114.029555},{lat:22.422033,lng:114.028292},{lat:22.418172,lng:114.025328},{lat:22.416252,lng:114.024020},{lat:22.416277,lng:114.021894}];

    const state = {
        driver: { phone:'', plate:'', mode:'busy', idx:0, dirBusy:false, dirNormal:false, pass:0, max:16, full:false, gpsId:null, gpsPollId:null, manualUntil:0, lastGpsTriggerIdx:-1, lastGpsTriggerTime:0, lastGpsAccuracy:null },
        passenger: { name:'', tracking:'', voice:false, lastStation:'', trackListener:null },
        voiceEnabled: localStorage.getItem('van_voice_enabled') !== 'false',
        msgListeners: { driverChild:null, passenger:null, driverValue:null },
        recorder: null, audioChunks:[], recordTarget:'', recordTimer:null,
        speakQueue:[], speaking:false, busListListener:null,
        useNewLayout: (localStorage.getItem('van_layout_v83')||'new')==='new',
        oldIdleTimer: null, autoReturnEnabled: true, oldResetIdleTimer: null,
        guideToggle: true, _gpsWatchErrorCount:0, wakeLock: null
    };

    const getStations = () => state.driver.mode==='busy' ? (state.driver.dirBusy ? [...BUSY].reverse() : BUSY) : (state.driver.dirNormal ? [...NORMAL].reverse() : NORMAL);
    const getCoords = () => state.driver.mode==='busy' ? (state.driver.dirBusy?[...COORDS_BUSY].reverse():COORDS_BUSY) : (state.driver.dirNormal?[...COORDS_NORMAL].reverse():COORDS_NORMAL);
    const dist = (lat1,lon1,lat2,lon2) => {
        const p=Math.PI/180, a=Math.sin((lat2-lat1)*p/2)**2+Math.cos(lat1*p)*Math.cos(lat2*p)*Math.sin((lon2-lon1)*p/2)**2;
        return 6371e3*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
    };
    const cleanStation = s => s.replace('(回程)','').replace('(終點站)','');
    const speak = (text, cb) => {
        if (!state.voiceEnabled || !('speechSynthesis' in window)) { if(cb) cb(); return; }
        state.speakQueue.push({text,cb});
        if (!state.speaking) processQueue();
    };
    const processQueue = () => {
        if (!state.speakQueue.length) { state.speaking=false; return; }
        state.speaking=true;
        const {text,cb} = state.speakQueue.shift();
        const u = new SpeechSynthesisUtterance(text);
        u.lang='zh-HK'; u.rate=0.9;
        u.onend = () => { if(cb) cb(); processQueue(); };
        u.onerror = () => processQueue();
        speechSynthesis.speak(u);
    };
    const toast = msg => {
        const t = document.getElementById('toast');
        t.textContent=msg; t.classList.add('show');
        clearTimeout(window._toastTimer); window._toastTimer=setTimeout(()=>t.classList.remove('show'),2000);
    };

    const showView = id => {
        document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    };

    // 全域語音開關
    const updateVoiceToggleUI = () => {
        const btn = document.getElementById('global-voice-toggle');
        if(btn) btn.textContent = state.voiceEnabled ? '🔊' : '🔇';
        const passBtn = document.getElementById('voice-toggle');
        if(passBtn) {
            passBtn.textContent = state.voiceEnabled ? '🔊 廣東話報站 ON' : '🔇 廣東話報站 OFF';
            passBtn.style.background = state.voiceEnabled ? '#30d158' : '#ff9f0a';
        }
    };
    document.getElementById('global-voice-toggle').onclick = () => {
        state.voiceEnabled = !state.voiceEnabled;
        localStorage.setItem('van_voice_enabled', state.voiceEnabled);
        updateVoiceToggleUI();
        toast(state.voiceEnabled ? '語音已開啟' : '語音已關閉');
    };

    // 公告鈴鐺系統
    const announceBell = document.getElementById('announce-bell');
    const announceFull = document.getElementById('announce-fullscreen');
    const announceFullText = document.getElementById('announce-full-text');
    let currentAnnounceText = '';
    announceRef.on('value', snap => {
        const v = snap.val();
        currentAnnounceText = v?.text || '';
        if (currentAnnounceText) {
            announceBell.style.display = 'flex';
            announceBell.classList.add('has-announce');
        } else {
            announceBell.style.display = 'none';
            announceBell.classList.remove('has-announce');
        }
    });
    announceBell.onclick = () => {
        if (currentAnnounceText) {
            announceFullText.textContent = currentAnnounceText;
            announceFull.style.display = 'flex';
        }
    };
    document.getElementById('close-full-announce').onclick = () => {
        announceFull.style.display = 'none';
    };

    // Wake Lock
    async function requestWakeLock() {
        try {
            if ('wakeLock' in navigator) {
                state.wakeLock = await navigator.wakeLock.request('screen');
                state.wakeLock.addEventListener('release', () => console.log('Wake lock released'));
            }
        } catch(e) {}
    }
    function releaseWakeLock() {
        if (state.wakeLock) { state.wakeLock.release(); state.wakeLock = null; }
    }

    // 儲存 / 還原司機會話
    const saveDriverSession = () => {
        const sd = state.driver;
        if (!sd.phone || !sd.plate) return;
        try { localStorage.setItem('van_driver_session', JSON.stringify({phone:sd.phone,plate:sd.plate,mode:sd.mode,idx:sd.idx,dirBusy:sd.dirBusy,dirNormal:sd.dirNormal,pass:sd.pass,max:sd.max,full:sd.full,savedAt:Date.now()})); } catch(e){}
    };
    const restoreDriverSession = () => {
        try {
            const raw = localStorage.getItem('van_driver_session');
            if (!raw) return false;
            const s = JSON.parse(raw);
            if (Date.now() - (s.savedAt||0) > 30*60*1000) { localStorage.removeItem('van_driver_session'); return false; }
            if (!s.phone || !s.plate) return false;
            state.driver.phone = s.phone; state.driver.plate = s.plate; state.driver.mode = s.mode||'busy';
            state.driver.idx = s.idx||0; state.driver.dirBusy = s.dirBusy||false; state.driver.dirNormal = s.dirNormal||false;
            state.driver.pass = s.pass||0; state.driver.max = s.max||16; state.driver.full = s.full||false;
            state.driver.gpsId = null; state.driver.gpsPollId = null; state.driver.manualUntil = 0; state.driver.lastGpsTriggerIdx = -1; state.driver.lastGpsTriggerTime = 0;
            return true;
        } catch(e) { return false; }
    };

    const updateAllDriverMessages = snap => {
        renderMessages(snap, 'driver-msg-list-overlay');
        renderMessages(snap, 'driver-msg-list-old');
    };
    const renderMessages = (snap, elId) => {
        const data = snap.val(), list = document.getElementById(elId);
        if (!list) return;
        list.innerHTML = '';
        if (!data) return;
        const cutoff = Date.now()-7*24*60*60*1000, updates={};
        Object.entries(data).forEach(([k,m])=>{
            if (m.ts<cutoff) { updates[k]=null; return; }
            const div = document.createElement('div');
            const time = new Date(m.ts).toLocaleTimeString('zh-HK',{hour:'2-digit',minute:'2-digit'});
            if (m.type==='audio') div.innerHTML = `[${m.from}] 🎤 <button class="play-audio" data-audio="${m.audioData}">▶️</button> <small>${time}</small>`;
            else div.textContent = `[${m.from}] ${m.text}  ${time}`;
            list.appendChild(div);
        });
        list.querySelectorAll('.play-audio').forEach(b=>b.addEventListener('click', ()=>new Audio('data:audio/webm;base64,'+b.dataset.audio).play()));
        list.scrollTop = list.scrollHeight;
        if (Object.keys(updates).length) snap.ref.update(updates);
    };

    const getMime = () => ['audio/webm','audio/mp4','audio/ogg; codecs=opus'].find(m=>MediaRecorder.isTypeSupported(m))||'';
    const startRec = async (target, timerId) => {
        if (state.recorder?.state==='recording') return;
        try {
            const stream = await navigator.mediaDevices.getUserMedia({audio:true});
            const mime = getMime();
            state.recorder = new MediaRecorder(stream, mime?{mimeType:mime}:{});
            state.audioChunks = []; state.recordTarget = target;
            state.recorder.ondataavailable = e => { if(e.data.size) state.audioChunks.push(e.data); };
            state.recorder.onstop = () => {
                clearInterval(state.recordTimer);
                if (!state.audioChunks.length) return;
                const blob = new Blob(state.audioChunks, {type:state.recorder.mimeType||'audio/webm'});
                const reader = new FileReader();
                reader.onloadend = () => {
                    const b64 = reader.result.split(',')[1];
                    const ref = target==='driver' ? msgRef.child(state.driver.phone) : msgRef.child(state.passenger.tracking);
                    const from = target==='driver'?`司機${state.driver.plate}`:`乘客:${state.passenger.name}`;
                    ref.push({from, type:'audio', audioData:b64, ts:Date.now()});
                };
                reader.readAsDataURL(blob);
                stream.getTracks().forEach(t=>t.stop());
            };
            state.recorder.start(1000);
            if (navigator.vibrate) navigator.vibrate(50);
            let sec=0;
            document.getElementById(timerId).textContent='0s';
            state.recordTimer = setInterval(()=>{ sec++; document.getElementById(timerId).textContent=sec+'s'; if(sec>=25&&navigator.vibrate)navigator.vibrate(30); if(sec>=30)stopRec(timerId); },1000);
        } catch(e) { toast('❌ 錄音失敗'); }
    };
    const stopRec = (timerId) => {
        if (state.recorder?.state==='recording') state.recorder.stop();
        clearInterval(state.recordTimer);
        if (timerId) document.getElementById(timerId).textContent='0s';
    };
    const setupRecBtn = (btnId, target, timerId) => {
        const btn = document.getElementById(btnId);
        btn.addEventListener('pointerdown', e => { e.preventDefault(); btn.classList.add('recording'); startRec(target, timerId); });
        const stop = () => { btn.classList.remove('recording'); stopRec(timerId); };
        btn.addEventListener('pointerup', stop); btn.addEventListener('pointerleave', stop); btn.addEventListener('pointercancel', stop);
    };

    // GPS
    const GPS_DIST_THRESHOLD = 100;
    const GPS_DEBOUNCE_MS = 12000;
    const GPS_POLL_INTERVAL = 8000;
    const stopGps = (uploadRemove=true) => {
        if (state.driver.gpsId) { navigator.geolocation.clearWatch(state.driver.gpsId); state.driver.gpsId=null; }
        if (state.driver.gpsPollId) { clearInterval(state.driver.gpsPollId); state.driver.gpsPollId=null; }
        state.driver.lastGpsTriggerIdx=-1; state.driver.lastGpsTriggerTime=0; state.driver.lastGpsAccuracy=null;
        state._gpsWatchErrorCount=0;
        updateGpsStatusDisplay(null,null);
        if (uploadRemove && state.driver.phone) activeRef.child(state.driver.phone).remove();
        releaseWakeLock();
    };
    const updateGpsStatusDisplay = (accuracy, isGood) => {
        const statusNew = document.getElementById('d-gps-status-new'), statusOld = document.getElementById('d-gps-status-old');
        const text = accuracy ? `📍 GPS 精度: ±${Math.round(accuracy)}m` : '📍 GPS: 搜尋中…';
        let cls = ''; if (isGood===true) cls='good'; else if (isGood===false) cls='bad'; else cls='warn';
        if(statusNew){ statusNew.textContent=text; statusNew.className='gps-status '+cls; }
        if(statusOld){ statusOld.textContent=text; statusOld.className='gps-status '+cls; }
    };
    const startGps = () => {
        if (!navigator.geolocation) return toast('❌ 此裝置不支援GPS');
        stopGps(false);
        state.driver.manualUntil=0; state.driver.lastGpsTriggerIdx=-1; state.driver.lastGpsTriggerTime=0; state._gpsWatchErrorCount=0;
        updateGpsStatusDisplay(null,null);
        requestWakeLock();
        const processPos = (pos, source) => {
            const now = Date.now();
            if (now < state.driver.manualUntil) return;
            const coords = getCoords(), list = getStations(), accuracy = pos.coords.accuracy||25;
            state.driver.lastGpsAccuracy = accuracy;
            const isGood = accuracy<30, isBad = accuracy>80;
            updateGpsStatusDisplay(accuracy, isBad?false:(isGood?true:null));
            if (state.driver.idx+1 < coords.length) {
                const dNext = dist(pos.coords.latitude, pos.coords.longitude, coords[state.driver.idx+1].lat, coords[state.driver.idx+1].lng);
                const distEl = state.useNewLayout ? null : document.getElementById('d-distance-old');
                if(distEl) distEl.innerHTML = `📍 ${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}<br>距下一站: ${Math.round(dNext)} 米 · 精度 ±${Math.round(accuracy)}m`;
            }
            const effectiveThreshold = Math.max(GPS_DIST_THRESHOLD, accuracy*1.8);
            let bestIdx=-1, bestDist=Infinity;
            for (let i=state.driver.idx; i<coords.length; i++) {
                const d = dist(pos.coords.latitude, pos.coords.longitude, coords[i].lat, coords[i].lng);
                if (d<effectiveThreshold && d<bestDist) { bestIdx=i; bestDist=d; }
            }
            if (bestIdx<0) return;
            if (bestIdx===state.driver.lastGpsTriggerIdx && now-state.driver.lastGpsTriggerTime<GPS_DEBOUNCE_MS) return;
            if (bestIdx>=state.driver.idx) {
                state.driver.idx = bestIdx;
                state.driver.lastGpsTriggerIdx = bestIdx;
                state.driver.lastGpsTriggerTime = now;
                const cur = cleanStation(list[bestIdx]), nxt = bestIdx+1<list.length?cleanStation(list[bestIdx+1]):null;
                speak(`即將到達：${cur}`, ()=>{ if(nxt) setTimeout(()=>speak(`下一站：${nxt}`),2000); });
                refreshDriverUI();
                if (bestIdx>=list.length-1) setTimeout(autoReverse,3000);
            }
        };
        state.driver.gpsId = navigator.geolocation.watchPosition(
            (pos)=>{ state._gpsWatchErrorCount=0; processPos(pos,'watch'); },
            (err)=>{ state._gpsWatchErrorCount++; if(state._gpsWatchErrorCount>=5) updateGpsStatusDisplay(null,false); },
            { enableHighAccuracy:true, maximumAge:8000, timeout:15000 }
        );
        state.driver.gpsPollId = setInterval(()=>{
            navigator.geolocation.getCurrentPosition((pos)=>processPos(pos,'poll'),()=>{}, { enableHighAccuracy:true, maximumAge:5000, timeout:10000 });
        }, GPS_POLL_INTERVAL);
        toast('🟢 GPS 報站已啟動');
    };
    const autoReverse = () => {
        if (state.driver.mode==='busy') state.driver.dirBusy=!state.driver.dirBusy;
        else state.driver.dirNormal=!state.driver.dirNormal;
        state.driver.idx=0; state.driver.pass=0; state.driver.full=false;
        state.driver.lastGpsTriggerIdx=-1; state.driver.lastGpsTriggerTime=0; state.driver.manualUntil=0;
        refreshDriverUI(); speak('已到達終點站，方向已自動切換，乘客數已清零');
    };

    const refreshNewUI = async (upload) => {
        const st=state.driver, list=getStations(), now=cleanStation(list[st.idx]), next=st.idx+1<list.length?cleanStation(list[st.idx+1]):'終點站';
        document.getElementById('d-info-new').textContent=`手機: ${st.phone||'未登入'} | 車牌: ${st.plate||'-'}`;
        document.getElementById('d-mode-badge-new').textContent=st.mode==='busy'?'繁忙時段':'非繁忙';
        const dirText=st.mode==='busy'?(st.dirBusy?'往大棠':'往元朗'):(st.dirNormal?'逆行':'順行');
        document.getElementById('d-dir-badge-new').textContent=dirText;
        document.getElementById('d-dir-badge-new').className=(st.mode==='busy'&&st.dirBusy)||(st.mode==='normal'&&st.dirNormal)?'badge badge-blue':'badge badge-red';
        document.getElementById('d-station-new').textContent=now;
        document.getElementById('d-target-new').textContent=`下一站：${next}`;
        document.getElementById('d-pass-count-new').textContent=st.pass;
        const fullBtn=document.getElementById('d-full-btn-new');
        if(st.full){ fullBtn.textContent='取消滿座'; fullBtn.className='btn btn-red'; } else { fullBtn.textContent='標記滿座'; fullBtn.className='btn btn-green'; }
        document.getElementById('d-car-btn-new').textContent=st.max+'座';
        document.getElementById('btn-prev-new').disabled=st.idx===0;
        document.getElementById('btn-next-new').disabled=st.idx===list.length-1;
        document.getElementById('d-route-strip-new').innerHTML = list.map((s,i)=>`<div class="dot-node${i===st.idx?' active':''}"><div class="dot"></div><span>${cleanStation(s)}</span></div>`).join('');
        document.getElementById('start-gps-new').style.display=st.gpsId?'none':'block';
        document.getElementById('stop-gps-new').style.display=st.gpsId?'block':'none';
        if(upload && st.phone && st.plate) {
            await activeRef.child(st.phone).set({phone:st.phone,plate:st.plate,routeMode:st.mode==='busy'?'繁忙時段':'非繁忙',direction:dirText,rawStationName:list[st.idx],passenger:st.pass,maxSeat:st.max,full:st.full,targetStation:next,ts:Date.now()});
            activeRef.child(st.phone).onDisconnect().remove();
        }
    };
    const refreshOldUI = async (upload) => {
        const st=state.driver, list=getStations(), now=cleanStation(list[st.idx]);
        document.getElementById('d-info-old').textContent=`手機: ${st.phone||'未登入'} | 車牌: ${st.plate||'未輸入'}`;
        document.getElementById('d-mode-display-old').textContent=st.mode==='busy'?'繁忙時段西鐵快線':'非繁忙時段市中心快線';
        document.getElementById('d-dir-display-old').textContent=st.mode==='busy'?(st.dirBusy?'往 大棠':'往 元朗'):(st.dirNormal?'🔄 往 大棠黃泥墩':'🔄 往 元朗站方向');
        document.getElementById('d-station-old').textContent=now;
        document.getElementById('d-pass-count-old').textContent=st.pass;
        document.getElementById('d-fullBtn-old').textContent=st.full?'取消滿座':'滿座';
        document.getElementById('d-fullBtn-old').className=st.full?'btn btn-red':'btn btn-green';
        document.getElementById('d-car16-old').style.background=st.max===16?'#ffcc00':'#333';
        document.getElementById('d-car19-old').style.background=st.max===19?'#ffcc00':'#333';
        document.getElementById('switch-dir-old').style.display=st.gpsId?'block':'none';
        document.getElementById('start-gps-old').style.display=st.gpsId?'none':'block';
        document.getElementById('stop-gps-old').style.display=st.gpsId?'block':'none';
        document.getElementById('d-route-container-old').style.display=st.gpsId?'flex':'none';
        document.getElementById('d-route-container-old').innerHTML = list.map((s,i)=>`<div class="dot-node${i===st.idx?' active':''}"><div class="dot"></div><span>${cleanStation(s)}</span></div>`).join('');
        if(upload && st.phone && st.plate) {
            await activeRef.child(st.phone).set({phone:st.phone,plate:st.plate,routeMode:st.mode==='busy'?'繁忙時段':'非繁忙',direction:st.mode==='busy'?(st.dirBusy?'往 大棠':'往 元朗'):(st.dirNormal?'🔄 往 大棠黃泥墩':'🔄 往 元朗站方向'),rawStationName:list[st.idx],passenger:st.pass,maxSeat:st.max,full:st.full,targetStation:cleanStation(list[st.idx+1]||'終點站'),ts:Date.now()});
            activeRef.child(st.phone).onDisconnect().remove();
        }
    };
    const refreshDriverUI = (upload=true) => {
        if(state.useNewLayout) refreshNewUI(upload); else refreshOldUI(upload);
        saveDriverSession();
    };

    const setupOldLayoutIdle = () => {
        const container = document.getElementById('driver-old-panel'), sec2 = document.getElementById('old-sec2'), sec3 = document.getElementById('old-sec3');
        const resetTimer = () => {
            if(state.oldIdleTimer) clearTimeout(state.oldIdleTimer);
            if(!state.autoReturnEnabled) return;
            state.oldIdleTimer = setTimeout(()=>{ sec2.scrollIntoView({behavior:'smooth'}); },15000);
        };
        state.oldResetIdleTimer = resetTimer;
        container.addEventListener('scroll', resetTimer, {passive:true});
        container.addEventListener('touchstart', resetTimer, {passive:true});
        container.addEventListener('click', ()=>{ state.autoReturnEnabled = true; resetTimer(); });
        if(state.msgListeners.driverChild) msgRef.child(state.driver.phone).off('child_added', state.msgListeners.driverChild);
        state.msgListeners.driverChild = msgRef.child(state.driver.phone).on('child_added', snap => {
            if(snap.val()?.from?.startsWith('乘客:')) { state.autoReturnEnabled = false; if(state.oldIdleTimer) clearTimeout(state.oldIdleTimer); sec3.scrollIntoView({behavior:'smooth'}); }
        });
        resetTimer();
    };
    const teardownOldLayoutIdle = () => {
        if(state.oldIdleTimer) clearTimeout(state.oldIdleTimer);
        if(state.msgListeners.driverChild) msgRef.child(state.driver.phone).off('child_added', state.msgListeners.driverChild);
        state.oldResetIdleTimer = null;
    };
    const switchLayout = (useNew) => {
        state.useNewLayout = useNew;
        localStorage.setItem('van_layout_v83', useNew?'new':'old');
        document.getElementById('driver-new-panel').style.display = useNew?'flex':'none';
        document.getElementById('driver-old-panel').style.display = useNew?'none':'block';
        if(!useNew) { teardownOldLayoutIdle(); setupOldLayoutIdle(); } else teardownOldLayoutIdle();
        bindDriverEvents(); refreshDriverUI(false);
    };
    const bindDriverEvents = () => {
        if(state.useNewLayout) {
            document.getElementById('btn-add-pass-new').onclick = ()=>{ if(state.driver.pass<state.driver.max){ state.driver.pass++; if(state.driver.pass===state.driver.max) state.driver.full=true; refreshDriverUI(); } };
            document.getElementById('btn-sub-pass-new').onclick = ()=>{ if(state.driver.pass>0){ state.driver.pass--; state.driver.full=false; refreshDriverUI(); } };
            document.getElementById('d-full-btn-new').onclick = ()=>{ state.driver.full=!state.driver.full; refreshDriverUI(); };
            document.getElementById('d-car-btn-new').onclick = ()=>{ state.driver.max=state.driver.max===16?19:16; if(state.driver.pass>=state.driver.max) state.driver.full=true; else state.driver.full=false; refreshDriverUI(); };
            document.getElementById('btn-prev-new').onclick = ()=>{ if(state.driver.idx>0){ state.driver.idx--; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; refreshDriverUI(); } };
            document.getElementById('btn-next-new').onclick = ()=>{ const list=getStations(); if(state.driver.idx<list.length-1){ state.driver.idx++; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; speak(`即將到達：${cleanStation(list[state.driver.idx])}`); refreshDriverUI(); } if(state.driver.idx>=list.length-1) autoReverse(); };
            document.getElementById('btn-switch-dir-new').onclick = ()=>{ if(state.driver.mode==='busy') state.driver.dirBusy=!state.driver.dirBusy; else state.driver.dirNormal=!state.driver.dirNormal; state.driver.idx=0; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; refreshDriverUI(); };
            document.getElementById('btn-mode-toggle-new').onclick = ()=>{ state.driver.mode=state.driver.mode==='busy'?'normal':'busy'; state.driver.idx=0; state.driver.dirBusy=false; state.driver.dirNormal=false; state.driver.lastGpsTriggerIdx=-1; refreshDriverUI(); };
            document.getElementById('start-gps-new').onclick = ()=>{ startGps(); refreshDriverUI(); };
            document.getElementById('stop-gps-new').onclick = ()=>{ stopGps(true); refreshDriverUI(false); };
            document.getElementById('btn-logout-new').onclick = ()=>{ stopGps(true); state.driver.phone=''; state.driver.plate=''; localStorage.removeItem('van_driver_session'); showView('view-lobby'); };
        } else {
            document.getElementById('btn-add-pass-old').onclick = ()=>{ if(state.driver.pass<state.driver.max){ state.driver.pass++; if(state.driver.pass===state.driver.max) state.driver.full=true; refreshDriverUI(); } };
            document.getElementById('btn-sub-pass-old').onclick = ()=>{ if(state.driver.pass>0){ state.driver.pass--; state.driver.full=false; refreshDriverUI(); } };
            document.getElementById('d-fullBtn-old').onclick = ()=>{ state.driver.full=!state.driver.full; refreshDriverUI(); };
            document.getElementById('d-car16-old').onclick = ()=>{ state.driver.max=16; if(state.driver.pass>=16) state.driver.full=true; else state.driver.full=false; refreshDriverUI(); };
            document.getElementById('d-car19-old').onclick = ()=>{ state.driver.max=19; if(state.driver.pass>=19) state.driver.full=true; else state.driver.full=false; refreshDriverUI(); };
            document.getElementById('btn-prev-old').onclick = ()=>{ if(state.driver.idx>0){ state.driver.idx--; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; refreshDriverUI(); } };
            document.getElementById('btn-next-old').onclick = ()=>{ const list=getStations(); if(state.driver.idx<list.length-1){ state.driver.idx++; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; speak(`即將到達：${cleanStation(list[state.driver.idx])}`); refreshDriverUI(); } if(state.driver.idx>=list.length-1) autoReverse(); };
            document.getElementById('switch-dir-old').onclick = ()=>{ if(state.driver.mode==='busy') state.driver.dirBusy=!state.driver.dirBusy; else state.driver.dirNormal=!state.driver.dirNormal; state.driver.idx=0; state.driver.manualUntil=Date.now()+10000; state.driver.lastGpsTriggerIdx=-1; refreshDriverUI(); };
            document.getElementById('d-mode-busy-old').onclick = ()=>{ state.driver.mode='busy'; state.driver.idx=0; state.driver.dirBusy=false; refreshDriverUI(); };
            document.getElementById('d-mode-normal-old').onclick = ()=>{ state.driver.mode='normal'; state.driver.idx=0; state.driver.dirNormal=false; refreshDriverUI(); };
            document.getElementById('start-gps-old').onclick = ()=>{ startGps(); refreshDriverUI(); };
            document.getElementById('stop-gps-old').onclick = ()=>{ stopGps(true); refreshDriverUI(false); };
            document.getElementById('btn-logout-old').onclick = ()=>{ stopGps(true); state.driver.phone=''; state.driver.plate=''; localStorage.removeItem('van_driver_session'); showView('view-lobby'); };
            document.getElementById('btn-driver-send-old').onclick = ()=>{ const txt=document.getElementById('driver-msg-input-old').value.trim(); if(txt){ msgRef.child(state.driver.phone).push({from:'司機'+state.driver.plate,type:'text',text:txt,ts:Date.now()}); document.getElementById('driver-msg-input-old').value=''; } };
            document.getElementById('btn-driver-clear-old').onclick = ()=>{ if(confirm('清除訊息？')) msgRef.child(state.driver.phone).remove(); };
        }
    };

    const renderBusList = () => {
        if(state.busListListener) activeRef.off('value', state.busListListener);
        state.busListListener = activeRef.on('value', snap => {
            const data=snap.val()||{}, now=Date.now(), container=document.getElementById('bus-list-container');
            const valid = Object.entries(data).filter(([k,v])=>v?.plate && (now-v.ts)<60000);
            container.innerHTML = valid.length ? valid.map(([phone,b])=>`<div class="card"><div style="font-size:22px; font-weight:bold;">${b.full?'🔴':'🟢'} ${b.plate}</div><div>📍 ${cleanStation(b.rawStationName||'')} · ${b.direction}</div><div>💺 ${b.passenger}/${b.maxSeat} · ${Math.round((now-b.ts)/1000)}秒前</div><button class="btn btn-portal track-btn" data-phone="${phone}">追蹤此車</button></div>`).join('') : '<div class="card">暫無小巴當值</div>';
            container.querySelectorAll('.track-btn').forEach(b=>b.addEventListener('click', function(){
                state.passenger.tracking = this.dataset.phone; state.passenger.lastStation = '';
                if(state.passenger.trackListener) activeRef.child(state.passenger.tracking).off('value', state.passenger.trackListener);
                showView('view-passenger'); updatePassengerView();
            }));
        });
    };
    const updatePassengerView = () => {
        if(!state.passenger.tracking) return;
        if(state.passenger.trackListener) activeRef.child(state.passenger.tracking).off('value', state.passenger.trackListener);
        if(state.msgListeners.passenger) msgRef.child(state.passenger.tracking).off('value', state.msgListeners.passenger);
        state.msgListeners.passenger = snap => renderMessages(snap, 'pass-msg-list');
        msgRef.child(state.passenger.tracking).on('value', state.msgListeners.passenger);
        state.passenger.trackListener = activeRef.child(state.passenger.tracking).on('value', snap => {
            const bus=snap.val(); if(!bus?.plate) return;
            const raw=bus.rawStationName||'', clean=cleanStation(raw);
            if(raw !== state.passenger.lastStation) { if(state.passenger.voice) speak(`小巴 ${bus.plate} 駛至：${clean}。`+(bus.full?'滿座':'')); state.passenger.lastStation = raw; }
            document.getElementById('pass-data-card').innerHTML = `<div>更新: ${new Date(bus.ts).toLocaleTimeString()}</div><span class="badge">${bus.routeMode}</span> <span class="badge badge-red">${bus.direction}</span><div class="station-name">${clean}</div><div>➡️ ${bus.targetStation}</div><div class="big-number" style="font-size:48px;">${bus.passenger??0}</div>${bus.full?'<div style="color:#ff453a;">⚠️ 滿座</div>':''}<div>車牌: ${bus.plate}</div>`;
        });
    };

    // 管理員後台
    const adminBusListener = () => {
        activeRef.on('value', snap => {
            const data=snap.val()||{}, now=Date.now(), list=document.getElementById('admin-bus-list');
            const valid = Object.entries(data).filter(([k,v])=>v?.plate);
            list.innerHTML = valid.map(([phone,b])=>`<div class="card"><b>${b.plate}</b> (${b.phone})<br>📍 ${cleanStation(b.rawStationName||'')} · ${b.direction}<br>🕒 ${new Date(b.ts).toLocaleTimeString()}<br><button class="btn btn-red admin-remove" data-phone="${phone}">強制下線</button></div>`).join('') || '<div>暫無巴士</div>';
            list.querySelectorAll('.admin-remove').forEach(b=>b.addEventListener('click', ()=>{ activeRef.child(b.dataset.phone).remove(); toast('已移除'); }));
        });
    };

    document.addEventListener('DOMContentLoaded', ()=>{
        updateVoiceToggleUI();
        document.getElementById('btn-guide-voice').onclick = ()=>{ speak(state.guideToggle?'歡迎使用西鐵小巴':'司機請點擊紅色按鈕登入'); state.guideToggle=!state.guideToggle; };
        document.getElementById('btn-passenger').onclick = ()=>{
            let name = localStorage.getItem('van_pass_name'); if(!name){ name=prompt('輸入WhatsApp號碼或暱稱：'); if(!name) return; localStorage.setItem('van_pass_name',name); }
            state.passenger.name=name; showView('view-passenger-list'); renderBusList();
        };
        document.getElementById('btn-driver').onclick = ()=>{
            const hadSession = restoreDriverSession();
            let phone=state.driver.phone||localStorage.getItem('van_drv_phone')||'', plate=state.driver.plate||localStorage.getItem('van_drv_plate')||'';
            if(hadSession && phone && plate) { if(!confirm(`還原上次駕駛記錄？\n車牌：${plate}\n路線：${state.driver.mode}`)) { localStorage.removeItem('van_driver_session'); state.driver.phone=''; state.driver.plate=''; } }
            if(!state.driver.phone) { phone=prompt('手機號碼',phone); if(!phone) return; state.driver.phone=phone; }
            if(!state.driver.plate) { plate=prompt('車牌',plate); if(!plate) return; state.driver.plate=plate.toUpperCase(); }
            localStorage.setItem('van_drv_phone',state.driver.phone); localStorage.setItem('van_drv_plate',state.driver.plate);
            if(state.msgListeners.driverValue) msgRef.child(state.driver.phone).off('value', state.msgListeners.driverValue);
            state.msgListeners.driverValue = msgRef.child(state.driver.phone).on('value', updateAllDriverMessages);
            showView('view-driver'); switchLayout(state.useNewLayout);
        };
        document.getElementById('btn-generate-qr').onclick = ()=>{ const n=prompt('乘客名稱：'); if(n){ document.getElementById('qr-box').style.display='block'; document.getElementById('qr-box').innerHTML='<div id="qrcode"></div><button class="btn btn-secondary" id="close-qr">關閉</button>'; new QRCode(document.getElementById('qrcode'),{text:window.location.href.split('?')[0]+'?passenger='+encodeURIComponent(n),width:200,height:200}); document.getElementById('close-qr').onclick=()=>document.getElementById('qr-box').style.display='none'; } };
        document.getElementById('fps-code').onclick = ()=>{ navigator.clipboard.writeText('122891914').then(()=>toast('已複製')); };
        document.getElementById('btn-switch-layout').onclick = ()=> switchLayout(!state.useNewLayout);
        document.getElementById('voice-toggle').onclick = function(){ state.voiceEnabled=!state.voiceEnabled; localStorage.setItem('van_voice_enabled',state.voiceEnabled); updateVoiceToggleUI(); };
        document.getElementById('btn-pass-send').onclick = ()=>{ const t=document.getElementById('pass-msg-input').value.trim(); if(t&&state.passenger.tracking){ msgRef.child(state.passenger.tracking).push({from:'乘客:'+state.passenger.name,type:'text',text:t,ts:Date.now()}); document.getElementById('pass-msg-input').value=''; } };
        document.getElementById('btn-pass-clear').onclick = ()=>{ if(confirm('清除訊息？')) msgRef.child(state.passenger.tracking).remove(); };
        setupRecBtn('btn-pass-record','passenger','pass-timer');
        document.getElementById('float-msg-btn').onclick = ()=> document.getElementById('msg-overlay').style.display='flex';
        document.getElementById('close-msg-overlay').onclick = ()=> document.getElementById('msg-overlay').style.display='none';
        document.getElementById('btn-driver-send-overlay').onclick = ()=>{ const t=document.getElementById('driver-msg-input-overlay').value.trim(); if(t){ msgRef.child(state.driver.phone).push({from:'司機'+state.driver.plate,type:'text',text:t,ts:Date.now()}); document.getElementById('driver-msg-input-overlay').value=''; } };
        document.getElementById('btn-driver-clear-overlay').onclick = ()=>{ if(confirm('清除訊息？')) msgRef.child(state.driver.phone).remove(); };
        setupRecBtn('btn-driver-record-overlay','driver','driver-timer-overlay');
        setupRecBtn('btn-driver-record-old','driver','driver-timer-old');
        document.getElementById('btn-back-list').onclick = ()=>{ if(state.busListListener) activeRef.off('value',state.busListListener); showView('view-lobby'); };
        document.getElementById('btn-back-track').onclick = ()=>{ if(state.passenger.trackListener) activeRef.child(state.passenger.tracking).off('value',state.passenger.trackListener); showView('view-passenger-list'); };
        document.getElementById('btn-publish-announce').onclick = ()=>{ const t=document.getElementById('announce-input').value.trim(); if(t) announceRef.child('text').set(t); };
        document.getElementById('btn-clear-announce').onclick = ()=> announceRef.child('text').remove();
        document.getElementById('btn-admin-back').onclick = ()=> showView('view-lobby');
        let clicks=0;
        document.getElementById('dev-tag').onclick = ()=>{ clicks++; if(clicks>=5){ clicks=0; const p=prompt('密碼：'); if(p==='Fai64989786'){ showView('view-admin'); adminBusListener(); } } clearTimeout(window._devTimer); window._devTimer=setTimeout(()=>clicks=0,3000); };
        const params = new URLSearchParams(window.location.search);
        if(params.has('passenger')){ state.passenger.name=params.get('passenger').trim(); localStorage.setItem('van_pass_name',state.passenger.name); showView('view-passenger-list'); renderBusList(); }
    });
    window.addEventListener('beforeunload', ()=>{ stopGps(true); teardownOldLayoutIdle(); if(state.msgListeners.driverValue&&state.driver.phone) msgRef.child(state.driver.phone).off('value',state.msgListeners.driverValue); if(state.busListListener) activeRef.off('value',state.busListListener); saveDriverSession(); });
    document.addEventListener('visibilitychange', ()=>{ if(document.hidden&&state.driver.phone) saveDriverSession(); });
})();
</script>
</body>
</html>
