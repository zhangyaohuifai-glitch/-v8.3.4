    <div class="card" id="admin-bus-list">載入中…</div>
    <div class="card">
        <textarea id="announce-input" style="width:100%; padding:12px; border-radius:12px; background:#2c2c2e; color:#fff; border:none; font-size:18px;" rows="3" placeholder="輸入公告內容"></textarea>
        <button class="btn btn-warn" id="btn-publish-announce">📢 發佈公告</button>
