            <button class="record-btn" id="btn-pass-record">🎤<span class="record-timer" id="pass-timer">0s</span></button>
            <input id="pass-msg-input" class="msg-input" placeholder="訊息…">
            <button class="send-btn" id="btn-pass-send">發</button>
