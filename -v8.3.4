    <div id="qr-box" class="card" style="display:none;"></div>
</div>

<!-- 乘客列表 -->
<div id="view-passenger-list" class="view">
    <h2 style="text-align:center; margin-bottom:12px;">🚐 線上小巴 (60秒內更新)</h2>
    <div id="bus-list-container">載入中…</div>
    <button class="btn btn-secondary" id="btn-back-list">返回大堂</button>
</div>

<!-- 乘客追蹤 -->
<div id="view-passenger" class="view">
