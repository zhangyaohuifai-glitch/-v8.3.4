        <button class="btn btn-secondary" id="btn-switch-layout" style="width:auto; padding:8px 16px; font-size:18px;">🔧 切換舊版面</button>
    </div>

    <div id="driver-new-panel" class="driver-panel-new" style="display:flex;">
        <div class="card" style="text-align:center; padding:12px;">
            <div style="font-size:18px; color:#aaa;" id="d-info-new">手機: 未登入 | 車牌: -</div>
